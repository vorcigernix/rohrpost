# Local overrides for the Event Router Platform scaffold.

BOOTSTRAP_ADMIN_EMAIL=admin@local.rohrpost
BOOTSTRAP_API_TOKEN=dev-admin-token
NATS_URL=nats://nats:4222
CONTROL_API_PORT=3001
CONTROL_API_DB_PATH=/data/control-plane.sqlite
CONTROL_API_HOST=0.0.0.0
RUNTIME_MANAGER_PORT=3002
RUNTIME_MANAGER_HOST=0.0.0.0
RUNTIME_MANAGER_REQUEST_TIMEOUT_MS=3000
DEFAULT_TENANT_ID=tenant_demo
DEFAULT_TENANT_NAME=Demo Tenant
ADAPTER_REDPANDA_PORT=3003
ADAPTER_REDPANDA_HOST=0.0.0.0
ADAPTER_REDPANDA_DELIVERY_LOG_PATH=/data/adapter-deliveries.jsonl
CONSOLE_PORT=3000
VITE_API_BASE_URL=http://localhost:3001
VITE_USE_MOCK_API=false
REDPANDA_CONNECT_IMAGE=docker.redpanda.com/redpandadata/connect:latest
MANIFEST_SOURCE=compose
